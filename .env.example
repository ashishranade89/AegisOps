# ─── Required (production) ───────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...

# ─── Optional integrations ─────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── Production security (recommended) ───────────────────────────────────────
# Protect all /api/incident/* routes. Clients send: Authorization: Bearer <key>
INCIDENT_API_KEY=

# Never send LLM keys from the browser in production (default: false)
ALLOW_CLIENT_API_KEYS=false

# ─── Persistence ───────────────────────────────────────────────────────────────
CHECKPOINT_DB_PATH=data/checkpoints.db
RUNS_DB_PATH=data/runs.db

# ─── Model overrides ───────────────────────────────────────────────────────────
# OPENROUTER_MODEL=google/gemini-2.5-flash

# ─── Local LLM (Ollama / LM Studio) ────────────────────────────────────────────
# OPENROUTER_BASE_URL=http://localhost:11434/v1
# OPENROUTER_MODEL=qwen2.5-coder:7b

# ─── Hackathon / local dev only ────────────────────────────────────────────────
# ALLOW_CLIENT_API_KEYS=true
