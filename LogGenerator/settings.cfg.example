# LogGenerator daemon configuration
#
# Copy this file to settings.cfg and adjust values as needed.
# The daemon reads this config to emit random log entries at configured intervals.

[output]
# Path to the output log file (relative to LogGenerator/ directory)
log_file = logs/incident.log

# Maximum size of log file in bytes before rotation
# Default: 10485760 bytes (10 MB)
# Set to 0 to disable rotation
max_bytes = 10485760

# Number of backup log files to keep
# Default: 5
backup_count = 5

[info]
# Source file containing info-level log entries (relative to LogGenerator/ directory)
source_file = Incidents-info.log

# Interval in seconds between info log emissions
# Default: 60 seconds
interval_seconds = 30

[warning]
# Source file containing warning-level log entries (relative to LogGenerator/ directory)
source_file = Incidents-warnings.log

# Interval in seconds between warning log emissions
# Default: 60 seconds
interval_seconds = 300

[critical]
# Source file containing critical-level log entries (relative to LogGenerator/ directory)
source_file = Incidents-Critical.log

# Interval in seconds between critical log emissions
# Default: 60 seconds
interval_seconds = 600
