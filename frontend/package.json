{
  "name": "vendor-outage-investigator-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port 5176 --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://127.0.0.1:5176 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.hackathon.vendor-outage-investigator",
    "productName": "AegisOps",
    "directories": { "output": "dist-electron" },
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" },
    "files": ["dist/**/*", "electron/**/*"],
    "extraResources": [
      { "from": "../", "to": "backend", "filter": ["**/*", "!.venv/**", "!frontend/**", "!*.egg-info/**"] }
    ]
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "^0.25.0",
    "@rollup/rollup-darwin-arm64": "^4.40.0"
  },
  "dependencies": {
    "@react-three/drei": "^9.115.0",
    "@react-three/fiber": "^8.17.0",
    "@tailwindcss/vite": "^4.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^6.20.0",
    "tailwind-merge": "^2.1.0",
    "tailwindcss": "^4.0.0",
    "three": "^0.176.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.176.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.0.0",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wait-on": "^8.0.0"
  }
}
